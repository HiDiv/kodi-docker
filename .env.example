# Kodi Docker configuration
KODI_DATA=./kodi_data
KODI_MODE=headless
KODI_RESOLUTION=1280x720

# Config overlay (saved Kodi settings)
#CONFIG_PATH=./config/kodi20

# Addon mount (optional, for development)
#ADDON_PATH=../my-addon

# Test directory (for e2e runner)
#TEST_DIR=./e2e/tests

# Ports (change if defaults conflict with other services)
HTTP_PORT=18080
WS_PORT=19090
VNC_PORT=15900
NOVNC_PORT=18000
EVENT_PORT=19777
